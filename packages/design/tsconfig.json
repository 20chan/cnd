{
  "extends": "../typescript/tsconfig.react.json",
  "compilerOptions": {
    "declaration": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"]
    },
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.css"],
}
