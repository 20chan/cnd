{
  "extends": "../typescript/tsconfig.react.json",
  "compilerOptions": {
    "outDir": "build",
    "rootDir": "src",
    "paths": {
      "#/*": ["./src/*"],
    },
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
  ],
  "exclude": [
    "src/routes/",
    "src/router.*",
    "src/routeTree.gen.*",
  ]
}
